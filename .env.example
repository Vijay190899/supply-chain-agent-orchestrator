# Copy to .env and fill in. Never commit the real .env.

# LLM provider. Works with any OpenAI-compatible endpoint.
#
# OpenAI (paid):
#   OPENAI_API_KEY=sk-...          LLM_MODEL=gpt-4o-mini        (leave base URL empty)
# Groq (free tier, console.groq.com):
#   OPENAI_API_KEY=gsk_...         LLM_MODEL=llama-3.3-70b-versatile
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Google AI Studio (free tier, aistudio.google.com):
#   OPENAI_API_KEY=AIza...         LLM_MODEL=gemini-2.5-flash
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini

# Tracing (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# External data APIs (or leave blank to use the mock providers)
WEATHER_API_KEY=
NEWS_API_KEY=

# State
CHECKPOINT_DB=orchestrator.sqlite

# App
LOG_LEVEL=INFO
ENVIRONMENT=local
