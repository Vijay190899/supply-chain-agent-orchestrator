# Copy to .env and fill in. Never commit the real .env.

# LLM provider
OPENAI_API_KEY=

# Tracing (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# External data APIs (or leave blank to use the mock providers)
WEATHER_API_KEY=
NEWS_API_KEY=

# State
CHECKPOINT_DB=orchestrator.sqlite

# App
LOG_LEVEL=INFO
ENVIRONMENT=local
